flowchart TB
    subgraph Inputs
        PWR["Power-on / Reset"]
    end

    subgraph ROW1 [" "]
        direction LR
        SERIAL["Init Serial (9600 baud)<br>& Serial2 for PMS5003"]
        I2C["Init I2C bus (Wire)<br>Set 400 kHz clock"]
        WIFI_MODE["Set WiFi.mode(WIFI_STA)"]
        OLED["Init OLED SSD1306<br>(0x3C address)"]
    end

    subgraph ROW2 [" "]
        direction LR
        CRED_CHK{"WiFi credentials<br>stored?"}
        PORTAL["setupWiFiFirstTime()<br>Create AP portal"]
        AUTO["WiFi.begin()<br>Auto-connect"]
    end

    subgraph ROW3 [" "]
        direction LR
        RTC_CHK{"isRTCValid()?"}
        LOAD_RTC["setTime() from<br>RTC registers<br>rtcSynced ← true"]
        NTP_CHK{"WiFi connected?"}
        NTP_SYNC["syncTimeFromNTP()<br>syncRTCFromSystemTime()<br>ntpSynced ← true"]
    end

    subgraph ROW4 [" "]
        direction LR
        SENSORS["Init PMS5003 (passive)<br>Init DHT22<br>Try BME680"]
        SD_INIT["SD.begin(SD_CS)"]
        DONE["Setup complete →<br>enter loop()"]
    end

    subgraph Outputs ["Outputs / Side-Effects"]
        direction LR
        G1["Global flags:<br>wifiConnected<br>rtcSynced<br>ntpSynced<br>bmeAvailable"]
        G2["Hardware ready:<br>OLED, PMS, DHT,<br>BME680, SD card"]
    end

    PWR --> SERIAL
    SERIAL --> I2C --> WIFI_MODE --> OLED

    OLED --> CRED_CHK
    CRED_CHK -- "No (first boot)" --> PORTAL
    CRED_CHK -- "Yes" --> AUTO

    PORTAL --> RTC_CHK
    AUTO --> RTC_CHK

    RTC_CHK -- "Yes" --> LOAD_RTC
    RTC_CHK -- "No" --> NTP_CHK

    LOAD_RTC --> NTP_CHK
    NTP_CHK -- "Yes" --> NTP_SYNC
    NTP_CHK -- "No" --> SENSORS

    NTP_SYNC --> SENSORS
    SENSORS --> SD_INIT --> DONE

    DONE --> G1
    DONE --> G2

    style ROW1 fill:none,stroke:none
    style ROW2 fill:none,stroke:none
    style ROW3 fill:none,stroke:none
    style ROW4 fill:none,stroke:none
